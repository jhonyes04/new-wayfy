# Variables del servidor — acceder con os.getenv('VARIABLE_NAME')

# Base de datos
DATABASE_URL=postgres://gitpod:postgres@localhost:5432/example

# Flask
FLASK_APP=src/app.py
FLASK_APP_KEY="any key works"
FLASK_DEBUG=1
DEBUG=TRUE

# IA — Obtener API key en: https://console.groq.com/keys
GROQ_API_KEY=

# Email de contacto
CONTACT_EMAIL=

# CORS
CORS_ALLOWED_ORIGINS=https://wayfy.onrender.com,http://localhost:3000

# JWT
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRES_HOURS=1