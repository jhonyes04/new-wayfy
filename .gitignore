# ignore all files starting with .
.*

# track this file .gitignore (i.e. do NOT ignore it)
!.gitignore
!.github

# do not ignore render files
!Dockerfile.render
!render.yml
!.render-buildpacks.json

# ignore OS generated files
ehthumbs.db
Thumbs.db

# ignore Editor files
*.sublime-project
*.sublime-workspace
*.komodoproject

# ignore log files and databases
*.log
*.sqlite

# ignore compiled files
*.com
*.class
*.dll
*.exe
*.o
*.so

# ignore packaged files
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# ignore node dependency directories
node_modules/

# Vite build output
dist/

# pnpm
.pnpm-store/

# instance
instance/

# backend
.venv
database.db
__pycache__/

# environment variables
.env
.env.local
.env.*.local

# misc
!.gitkeep
!.htaccess
!.eslintrc
!.env.example
diagram.png